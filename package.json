{
  "name": "tocco-mate",
  "version": "1.0.0",
  "private": true,
  "description": "Inoffizieller Scraper fuer das WISS Tocco-Schulportal (Noten + Stundenplan) mit Dashboard, Scheduler und Telegram-Bot",
  "main": "cli.js",
  "scripts": {
    "start": "node --experimental-sqlite --no-warnings=ExperimentalWarning src/cli.js",
    "serve": "node --experimental-sqlite --no-warnings=ExperimentalWarning src/server.js",
    "setup": "playwright install chromium"
  },
  "dependencies": {
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.0.0",
    "playwright": "1.59.1"
  }
}
