# Tocco WISS CLI — Konfiguration
# Diese Datei als ".env" speichern (ohne ".example") und Werte eintragen.
#
# WICHTIG: .env enthält Secrets — NIE committen oder teilen.

# =============================================================
# AUTH (optional)
# =============================================================
# API-Token für ALLE /api/*-Routen und das Web-UI-Login.
# Wenn NICHT gesetzt, wird beim ersten Start automatisch ein sicherer Token
# generiert, in data/.api-token gespeichert und im Log ausgegeben.
#
# Empfohlen: mindestens 32 zufällige Zeichen.
# Generieren:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# API_TOKEN=

# Erlaube die Änderung von msPassword / telegramToken über das Web-UI.
# Default: false (Secrets dürfen NUR via .env gesetzt werden, nicht via API).
# Auf "true" setzen, wenn du bequem im Browser editieren willst (etwas weniger sicher,
# weil das Passwort dann auf Platte in data/settings.json landet).
ALLOW_UI_CREDENTIALS=false

# =============================================================
# MICROSOFT SSO (PFLICHT für Scraping)
# =============================================================
MS_EMAIL=dein.name@wiss-edu.ch
MS_PASSWORD=

# =============================================================
# TOCCO-URLs (nur via ENV änderbar — NICHT via Web-UI, SSRF-Schutz)
# =============================================================
# USER_PK=
# TOCCO_BASE=https://wiss.tocco.ch
# NOTEN_URL=https://wiss.tocco.ch/extranet/Meine-Bildung/Noten-f%C3%BCr-Studierende
# STUNDENPLAN_URL=https://wiss.tocco.ch/extranet/Meine-Bildung/Stundenplan-f%C3%BCr-Studierende

# =============================================================
# BROWSER
# =============================================================
# HEADLESS=true         # default: true. "false" = Browser sichtbar (Debug)
# SLOW_MO=0             # ms zwischen Playwright-Aktionen (Debug)
# DEBUG_SCRAPER=false   # "true" aktiviert ausführliche DOM-Dumps bei Scraper-Fehlern

# =============================================================
# SERVER
# =============================================================
# PORT=3000

# =============================================================
# DOCKER PERMISSIONS (nur relevant beim Container-Start)
# =============================================================
# PUID/PGID = User-/Group-ID auf dem Host, der das ./data-Verzeichnis besitzt.
# Der Container chownt das Volume beim Start auf diese Werte. Verhindert das
# typische "EACCES: permission denied"-Problem bei Bind-Mounts.
#
# So findest du deine Werte heraus:
#   Linux/macOS:   id -u  und  id -g
#   Unraid:        meist  PUID=99   PGID=100
#   Synology:      meist  PUID=1026 PGID=100
# PUID=1000
# PGID=1000

# Zeitzone für Log- und Telegram-Zeitstempel.
# Default: Europe/Zurich. Liste aller Zonen:
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Andere Beispiele: Europe/Berlin, Europe/Vienna, America/New_York, Etc/UTC
# TZ=Europe/Zurich

# =============================================================
# TELEGRAM-BOT (optional)
# =============================================================
# 1. Bot via @BotFather erstellen -> Token holen
# 2. Eigene User-ID via @userinfobot holen
# 3. Werte hier eintragen + TELEGRAM_ENABLED=true
# TELEGRAM_ENABLED=true
# TELEGRAM_TOKEN=1234567890:AAAA-BBBBCCCC_DDDDEEEEE
# TELEGRAM_ALLOWED_USER_ID=123456789
